{
  "name": "url-sanitizer",
  "description": "URL sanitizer for Node.js, browsers and web sites.",
  "author": "asamuzaK",
  "license": "MIT",
  "homepage": "https://github.com/asamuzaK/urlSanitizer",
  "bugs": "https://github.com/asamuzaK/urlSanitizer/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asamuzaK/urlSanitizer.git"
  },
  "files": [
    "dist",
    "src",
    "types"
  ],
  "type": "module",
  "exports": {
    "browser": "./dist/url-sanitizer-wo-dompurify.min.js",
    "default": {
      "types": "./types/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "types": "types/index.d.ts",
  "dependencies": {
    "dompurify": "^3.3.2",
    "jsdom": "^28.1.0"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.3.5",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "commander": "^14.0.3",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "eslint-plugin-jsdoc": "^62.7.1",
    "eslint-plugin-regexp": "^3.0.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "http-server": "^14.1.1",
    "mocha": "^11.7.5",
    "native-copyfiles": "^2.0.1",
    "neostandard": "^0.13.0",
    "npm-run-all2": "^8.0.4",
    "papaparse": "^5.5.3",
    "sinon": "^21.0.2",
    "typescript": "^5.9.3",
    "undici": "^7.22.0"
  },
  "overrides": {
    "c8": {
      "yargs": "^18.0.0"
    },
    "serialize-javascript": "^7.0.4"
  },
  "scripts": {
    "build": "npm run include && npm run tsc && npm run lint && npm test && npm run copy && npm run bundle",
    "bundle": "npm-run-all -s bundle:*",
    "bundle:min": "esbuild --format=esm --platform=browser --outfile=dist/url-sanitizer.min.js --bundle --minify --sourcemap bundle/index.js",
    "bundle:min-wo-dompurify": "esbuild --format=esm --platform=browser --outfile=dist/url-sanitizer-wo-dompurify.min.js --bundle --minify --sourcemap bundle_wo_dompurify/index.js",
    "char": "node scripts/index char -i",
    "copy": "npm-run-all -s copy:*",
    "copy:src": "copyfiles src/**/* bundle --up=1 --verbose --exclude=src/mjs/dompurify.js --exclude=src/mjs/file-reader.js --exclude=src/mjs/lib-util.js",
    "copy:src-wo-dompurify": "copyfiles src/**/* bundle_wo_dompurify --up=1 --verbose --exclude=src/mjs/dompurify.js --exclude=src/mjs/file-reader.js --exclude=src/mjs/lib-util.js",
    "copy:repl": "copyfiles repl/dompurify.js repl/file-reader.js repl/lib-util.js bundle/mjs --up=1 --verbose",
    "copy:repl-wo-dompurify": "copyfiles repl/dompurify-global.js repl/file-reader.js repl/lib-util.js bundle_wo_dompurify/mjs --up=1 --verbose && node scripts/index rename --oldpath=bundle_wo_dompurify/mjs/dompurify-global.js --newpath=bundle_wo_dompurify/mjs/dompurify.js -i",
    "include": "node scripts/index include --dir=iana -i",
    "lint": "eslint --fix .",
    "test": "c8 --reporter=text mocha --exit test/*.test.js",
    "test:bdd": "http-server ./ -c-1 -o test/bdd/url-sanitizer.test.html",
    "tsc": "node scripts/index clean --dir=types -i && npx tsc"
  },
  "version": "2.0.11"
}
